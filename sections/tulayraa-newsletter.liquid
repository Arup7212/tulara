{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="tulayraa-newsletter color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="tulayraa-newsletter__content" data-aos="fade-up">
      <div class="tulayraa-hero__tagline">Stay Balanced</div>
      <h2 class="tulayraa-hero__title" style="font-size: clamp(2rem, 4vw, 3rem); margin-bottom: 2rem;">Ritual Reflections</h2>
      <p class="tulayraa-philosophy__text" style="max-width: 600px; margin: 0 auto 3rem;">Receive curated beauty wisdom, self-care rituals, and exclusive sanctuary updates directly in your inbox.</p>

      {% form 'customer', class: 'newsletter-form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="newsletter-form__field">
          <input
            id="NewsletterForm--{{ section.id }}"
            type="email"
            name="contact[email]"
            class="newsletter-input"
            value="{{ form.email }}"
            aria-required="true"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
            {% if form.errors %}
              autofocus
              aria-invalid="true"
              aria-describedby="Newsletter-error--{{ section.id }}"
            {% elsif form.posted_successfully? %}
              aria-describedby="Newsletter-success--{{ section.id }}"
            {% endif %}
            placeholder="your@email.com"
            required
          >
          <button type="submit" class="tulayraa-btn tulayraa-btn--primary" name="commit" id="Subscribe">
            Join the Sanctuary
          </button>
        </div>
        {%- if form.errors -%}
          <small class="newsletter-form__message form__message--error" id="Newsletter-error--{{ section.id }}">
            {{- form.errors.translated_fields.email | capitalize }}
            {{ form.errors.messages.email -}}
          </small>
        {%- endif -%}
        {%- if form.posted_successfully? -%}
          <h3 class="newsletter-form__message form__message--success" id="Newsletter-success--{{ section.id }}" tabindex="-1" autofocus>
            Welcome to the Sanctuary.
          </h3>
        {%- endif -%}
      {% endform %}
    </div>
  </div>
</div>

<style>
  .tulayraa-newsletter {
    background-color: var(--tulayraa-ivory);
    text-align: center;
    border-top: 1px solid var(--tulayraa-beige);
  }

  .tulayraa-newsletter__content {
    max-width: 800px;
    margin: 0 auto;
  }

  .newsletter-form {
    max-width: 500px;
    margin: 0 auto;
  }

  .newsletter-form__field {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .newsletter-input {
    flex: 1;
    min-width: 250px;
    padding: 1rem 1.5rem;
    border-radius: 50px;
    border: 1px solid var(--tulayraa-champagne);
    background: white;
    font-family: var(--font-body-family);
    outline: none;
    transition: border-color 0.3s ease;
  }

  .newsletter-input:focus {
    border-color: var(--tulayraa-taupe);
  }

  @media screen and (max-width: 749px) {
    .newsletter-form__field {
      flex-direction: column;
    }
    .newsletter-input {
      width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "Tulayraa Newsletter",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Tulayraa Newsletter"
    }
  ]
}
{% endschema %}
