{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .bridal-exp-{{ section.id }} {
    position: relative;
    overflow: hidden;
  }

  .bridal-exp__container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
  }

  @media screen and (min-width: 990px) {
    .bridal-exp__container {
      grid-template-columns: 1fr 1.1fr;
      gap: 6rem;
    }
  }

  .bridal-exp__visual {
    position: relative;
  }

  .bridal-exp__main-image-wrap {
    width: 100%;
    border-radius: 40px;
    overflow: hidden;
    aspect-ratio: 4/5.2;
  }

  .bridal-exp__main-image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .bridal-exp__floating-icon-wrap {
    position: absolute;
    right: -30px;
    top: 50%;
    transform: translateY(-50%);
    width: 100px;
    height: 100px;
    background: var(--tulayraa-beige);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    z-index: 2;
    border: 4px solid #FFFFFF;
    overflow: hidden;
  }

  .bridal-exp__floating-icon-wrap img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 10px;
  }

  .bridal-exp__floating-icon-wrap svg {
    width: 40px;
    height: 40px;
    color: #2E2A24;
  }

  .bridal-exp__content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .bridal-exp__eyebrow-wrap {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .bridal-exp__eyebrow {
    font-family: var(--font-body-family);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #B98A5B;
  }

  .bridal-exp__eyebrow-line {
    height: 1px;
    width: 30px;
    background: #B98A5B;
    opacity: 0.3;
  }

  .bridal-exp__heading {
    margin: 0;
    font-family: var(--font-heading-family);
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.2;
    color: var(--color-foreground);
    font-weight: 400;
  }

  .bridal-exp__divider {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin: 0.2rem 0;
  }

  .bridal-exp__divider-line {
    height: 2px;
    width: 50px;
    background: #B98A5B;
  }

  .bridal-exp__divider-dot {
    width: 5px;
    height: 5px;
    background: #B98A5B;
    border-radius: 50%;
  }

  .bridal-exp__description {
    font-family: var(--font-body-family);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-foreground);
    opacity: 0.85;
    max-width: 520px;
  }

  .bridal-exp__benefits {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 1rem 0;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .bridal-exp__benefit-item {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    padding-bottom: 0.8rem;
    border-bottom: 1px solid rgba(var(--color-foreground-rgb), 0.05);
  }

  .bridal-exp__benefit-icon {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .bridal-exp__benefit-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .bridal-exp__benefit-icon svg {
    width: 20px;
    height: 20px;
    color: #B98A5B;
  }

  .bridal-exp__benefit-text {
    font-family: var(--font-body-family);
    font-size: 0.95rem;
    color: var(--color-foreground);
  }

  .bridal-exp__actions .tulayraa-btn {
    width: fit-content;
    gap: 2rem;
  }

  @media screen and (max-width: 989px) {
    .bridal-exp__floating-icon-wrap {
      right: 50%;
      top: auto;
      bottom: -25px;
      transform: translateX(50%);
    }
    .bridal-exp__content {
      padding-top: 1.5rem;
      text-align: center;
      align-items: center;
    }
    .bridal-exp__eyebrow-wrap {
      justify-content: center;
    }
    .bridal-exp__divider {
      justify-content: center;
    }
    .bridal-exp__benefit-item {
      justify-content: center;
      border-bottom: none;
    }
  }
{%- endstyle -%}

<div class="bridal-exp-{{ section.id }} section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="bridal-exp__container">
      
      <!-- Visual Column -->
      <div class="bridal-exp__visual" data-aos="fade-right">
        <div class="bridal-exp__main-image-wrap">
          {%- if section.settings.image != blank -%}
            {{ section.settings.image | image_url: width: 1500 | image_tag: 
              class: 'bridal-exp__main-image',
              loading: 'lazy',
              widths: '375, 550, 750, 1100, 1500'
            }}
          {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg bridal-exp__main-image' }}
          {%- endif -%}
        </div>

        <div class="bridal-exp__floating-icon-wrap">
          {%- if section.settings.floating_image != blank -%}
            {{ section.settings.floating_image | image_url: width: 200 | image_tag: 
              loading: 'lazy'
            }}
          {%- else -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          {%- endif -%}
        </div>
      </div>

      <!-- Content Column -->
      <div class="bridal-exp__content" data-aos="fade-left">
        <div class="bridal-exp__eyebrow-wrap">
          <span class="bridal-exp__eyebrow">{{ section.settings.eyebrow }}</span>
          <span class="bridal-exp__eyebrow-line"></span>
        </div>

        <h2 class="bridal-exp__heading">{{ section.settings.heading }}</h2>

        <div class="bridal-exp__divider">
          <div class="bridal-exp__divider-line"></div>
          <div class="bridal-exp__divider-dot"></div>
        </div>

        <div class="bridal-exp__description">
          {{ section.settings.description }}
        </div>

        {%- if section.blocks.size > 0 -%}
          <ul class="bridal-exp__benefits">
            {%- for block in section.blocks -%}
              <li class="bridal-exp__benefit-item" {{ block.shopify_attributes }}>
                <div class="bridal-exp__benefit-icon">
                  {%- if block.settings.image != blank -%}
                    {{ block.settings.image | image_url: width: 100 | image_tag: loading: 'lazy' }}
                  {%- else -%}
                    {%- case block.settings.icon -%}
                      {%- when 'leaf' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M11 20L7 14.94C3.55 10.57 3.69 4.39 12 2C20.31 4.39 20.45 10.57 17 14.94L13 20" stroke-linecap="round" stroke-linejoin="round"/><path d="M12 20V10" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      {%- when 'drop' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      {%- when 'sparkle' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      {%- when 'heart' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    {%- endcase -%}
                  {%- endif -%}
                </div>
                <span class="bridal-exp__benefit-text">{{ block.settings.text }}</span>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- if section.settings.button_label != blank -%}
          <div class="bridal-exp__actions">
            <a href="{{ section.settings.button_link }}" class="tulayraa-btn tulayraa-btn--primary">
              {{ section.settings.button_label }}
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Tulayraa Bridal Exp",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main Image"
    },
    {
      "type": "image_picker",
      "id": "floating_image",
      "label": "Floating Round Image/Icon"
    },
    {
      "type": "inline_richtext",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "THE ART OF RITUAL"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Flawless Rituals for Your Most Sacred Day."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Our luxury nail rituals are designed to restore balance, enhance your natural beauty, and make every moment feel extraordinary.</p>"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "BOOK YOUR RITUAL"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 100
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom Icon (PNG)"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Or Select SVG Icon",
          "options": [
            { "value": "leaf", "label": "Leaf" },
            { "value": "drop", "label": "Drop" },
            { "value": "sparkle", "label": "Sparkle" },
            { "value": "heart", "label": "Heart" }
          ],
          "default": "leaf"
        },
        {
          "type": "inline_richtext",
          "id": "text",
          "label": "Benefit Text",
          "default": "Benefit detail goes here"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Tulayraa Bridal Exp",
      "blocks": [
        { "type": "benefit", "settings": { "icon": "leaf", "text": "Strengthens natural nails" } },
        { "type": "benefit", "settings": { "icon": "drop", "text": "Long-lasting, flawless shine" } },
        { "type": "benefit", "settings": { "icon": "sparkle", "text": "Premium oils & skin care" } },
        { "type": "benefit", "settings": { "icon": "heart", "text": "Relaxing spa-like experience" } }
      ]
    }
  ]
}
{% endschema %}
