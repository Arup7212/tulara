                   <span>Professional Consultation</span>
                </div>
                <div class="inclusion-item">
                   <div class="inclusion-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 3h12l1 9H5l1-9z"></path><path d="M9 12v8a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2v-8"></path></svg></div>
                   <span>Signature Gel Application</span>
                </div>
                <div class="inclusion-item">
                   <div class="inclusion-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg></div>
                   <span>Premium Aftercare Oil</span>
                </div>
                <div class="inclusion-item">
                   <div class="inclusion-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg></div>
                   <span>Home Service Excellence</span>
                </div>
             </div>
          </div>

            {% form 'product', product %}
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              
              {% if product.variants.size > 1 and product.has_only_default_variant == false %}
                <div class="standard-variants-v2" style="margin-top: 3rem;">
                  <label class="meta-label">Selection</label>
                  <select name="id" class="ritual-select-custom">
                    {% for variant in product.variants %}
                      <option value="{{ variant.id }}" {% if variant == product.selected_or_first_available_variant %}selected{% endif %}>
