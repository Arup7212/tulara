  .addon-card__body { flex: 1; }
  .addon-card__name { font-size: 1.2rem; font-weight: 800; margin: 0 0 0.25rem; }
  .addon-card__desc { font-size: 0.85rem; color: var(--ritual-taupe); margin-bottom: 0.5rem; }
  .addon-price { font-weight: 700; font-size: 1rem; color: var(--ritual-charcoal); }

  .addon-add-btn {
    padding: 0.8rem 2.2rem;
    background: white;
    border: 1.5px solid var(--ritual-sage);
    color: var(--ritual-sage);
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 800;
    cursor: pointer;
    transition: 0.3s;
  }
  .addon-add-btn.added { background: var(--ritual-sage); color: white; border-color: var(--ritual-sage); }
  .addon-add-btn:hover { background: var(--ritual-sage); color: white; }

  /* Sticky Bar */
  .ritual-sticky-bar-wrapper { position: fixed; bottom: 2.5rem; left: 50%; transform: translateX(-50%); z-index: 1000; width: auto; max-width: 90vw; }
  .ritual-pill-bar {
    background: var(--ritual-sage);
    padding: 0.75rem 0.75rem 0.75rem 2.5rem;
    border-radius: 100px;
    display: flex;
    align-items: center;
    gap: 4rem;
    box-shadow: 0 30px 60px rgba(0,0,0,0.2);
    border: 1px solid rgba(255,255,255,0.1);
    backdrop-filter: blur(10px);
  }
  .pill-bar__left { display: flex; align-items: center; gap: 1.5rem; color: white; }
  .selection-count { width: 36px; height: 36px; background: white; color: var(--ritual-sage); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 0.85rem; }
  .pill-price { font-size: 1.75rem; font-weight: 800; line-height: 1; }
  .pill-label { font-size: 0.65rem; font-weight: 800; letter-spacing: 0.1em; opacity: 0.7; margin-top: 0.3rem; }

  .book-now-btn {
    padding: 1.1rem 2.5rem;
    background: white;
    color: var(--ritual-sage);
    border: none;
    border-radius: 100px;
    font-weight: 900;
    font-size: 0.9rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    transition: 0.3s;
  }
  .book-now-btn:hover { transform: scale(1.05); box-shadow: 0 10px 30px rgba(0,0,0,0.1); }

  /* Modal */
  .ritual-booking-modal { position: fixed; inset: 0; z-index: 2000; display: flex; align-items: center; justify-content: center; }
  .modal-overlay { position: absolute; inset: 0; background: rgba(15, 23, 42, 0.7); backdrop-filter: blur(15px); }
  .modal-container { position: relative; background: white; width: 100%; max-width: 650px; height: 90vh; border-radius: 40px; overflow: hidden; display: flex; flex-direction: column; }
  .modal-header { padding: 3rem 4rem; background: var(--ritual-cream); display: flex; justify-content: space-between; align-items: flex-start; }
  .modal-header h2 { font-size: 2rem; font-weight: 800; margin: 0 0 0.5rem; }
  .modal-header p { color: var(--ritual-taupe); font-weight: 600; margin: 0; }
  .modal-close-btn { background: none; border: none; cursor: pointer; color: var(--ritual-taupe); }

  .modal-steps-container { flex: 1; padding: 4rem; overflow-y: auto; }
  .step-label { font-size: 0.85rem; font-weight: 800; color: var(--ritual-taupe); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 2rem; }

  .calendar-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 10px; }
  .calendar-day { aspect-ratio: 1; display: flex; align-items: center; justify-content: center; border-radius: 50%; font-weight: 700; cursor: pointer; transition: 0.2s; background: var(--ritual-beige); }
  .calendar-day.active { background: var(--ritual-charcoal); color: white; }
  /* Modal Redesign */
  .booking-modal__content {
    position: relative;
    width: 100%;
    max-width: 960px;
    background: white;
    border-radius: 40px;
    overflow: hidden;
    box-shadow: 0 40px 100px rgba(0, 0, 0, 0.1);
    display: flex;
    height: 700px;
    max-height: 90vh;
    text-align: left;
  }

  .booking-sidebar {
    width: 35%;
    background: #F8F8F6;
    padding: 4rem 3.5rem;
    display: flex;
    flex-direction: column;
    border-right: 1px solid rgba(0,0,0,0.03);
  }

  .booking-brand__name {
    font-family: var(--font-heading-family);
