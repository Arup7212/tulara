  .time-slot.selected { background: #F7E7CE; color: var(--ritual-charcoal); }

  .booking-footer { margin-top: auto; display: flex; justify-content: space-between; align-items: center; padding-top: 4rem; }
  .btn-cancel { display: flex; align-items: center; gap: 0.8rem; background: none; border: 1.5px dashed #D0D0D0; padding: 0.9rem 2.2rem; border-radius: 100px; cursor: pointer; font-size: 0.95rem; color: #777; transition: 0.3s; }
  .btn-continue { background: var(--ritual-charcoal); color: white; padding: 1rem 3rem; border-radius: 100px; border: none; display: flex; align-items: center; gap: 1.2rem; font-size: 1rem; font-weight: 600; cursor: pointer; transition: 0.4s; }
