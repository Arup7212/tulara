<script>
  function tulayraaRitual() {
    return {
      ritualStarted: false,
      summaryOpen: false,
      selectedAddOns: [],
      modalOpen: false,
      currentStep: 1,
      bookingDate: null,
      bookingTime: null,
      address: { full: '', city: '', pincode: '', phone: '' },
      notes: '',
      loading: false,
      showError: false,
      currentMonth: new Date().getMonth(),
      currentYear: new Date().getFullYear(),
      monthNames: ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"],
      days: [],
      timeSlots: ['10:00 AM', '11:30 AM', '1:00 PM', '3:30 PM', '5:00 PM', '6:30 PM'],
      basePrice: {{ product.price | json }},
      productTitle: {{ product.title | json }},
      variantId: {{ product.selected_or_first_available_variant.id | json }},

      currentImageIndex: 0,
      images: [
        {% for image in product.images %}
          {{ image | image_url: width: 1400 | json }}{% unless forloop.last %},{% endunless %}
        {% endfor %}
      ],

      init() {
        this.generateCalendar();
        
        {% if product.metafields.custom.add_on_services.value != blank %}
        // Only restore ritual state for products that have add-ons
        const savedRitual = localStorage.getItem('tulayraa_ritual_started');
        if (savedRitual === 'true') {
          this.ritualStarted = true;
          const savedAddOns = localStorage.getItem('tulayraa_selected_addons');
          if (savedAddOns) {
            this.selectedAddOns = JSON.parse(savedAddOns);
          }
        }
        {% else %}
        // For simple products: clear any leftover state from other products
        localStorage.removeItem('tulayraa_ritual_started');
        localStorage.removeItem('tulayraa_selected_addons');
        {% endif %}
      },

      updateMainImage(src, index) {
        this.currentImageIndex = index;
        if (this.$refs.mainImg) {
          this.$refs.mainImg.src = src;
        }
      },

      nextImage() {
        this.currentImageIndex = (this.currentImageIndex + 1) % this.images.length;
        this.updateMainImage(this.images[this.currentImageIndex], this.currentImageIndex);
      },

      prevImage() {
        this.currentImageIndex = (this.currentImageIndex - 1 + this.images.length) % this.images.length;
        this.updateMainImage(this.images[this.currentImageIndex], this.currentImageIndex);
      },

      generateCalendar() {
        this.days = [];
        const firstDay = new Date(this.currentYear, this.currentMonth, 1).getDay();
        const daysInMonth = new Date(this.currentYear, this.currentMonth + 1, 0).getDate();
        
        for (let i = 0; i < firstDay; i++) {
          this.days.push({ num: '', full: '', available: false });
        }
        
        const now = new Date();
        now.setHours(0,0,0,0);

        for (let i = 1; i <= daysInMonth; i++) {
          const d = new Date(this.currentYear, this.currentMonth, i);
          this.days.push({
            num: i,
            full: d.toISOString().split('T')[0],
            available: d >= now
          });
        }
      },

      nextMonth() {
        if (this.currentMonth === 11) {
          this.currentMonth = 0;
          this.currentYear++;
        } else {
          this.currentMonth++;
        }
        this.generateCalendar();
      },

      prevMonth() {
        if (this.currentMonth === 0) {
          this.currentMonth = 11;
          this.currentYear--;
        } else {
          this.currentMonth--;
        }
        this.generateCalendar();
      },

      handleContinue() {
        if (this.currentStep === 1) {
          if (!this.bookingDate || !this.bookingTime) {
            this.showError = true;
            setTimeout(() => { this.showError = false; }, 3000);
            return;
          }
          this.currentStep = 2;
        } else {
          this.completeRitual();
        }
      },

      resetRitual() {
        this.ritualStarted = false;
        this.summaryOpen = false;
        this.selectedAddOns = [];
        localStorage.removeItem('tulayraa_ritual_started');
        localStorage.removeItem('tulayraa_selected_addons');
        window.scrollTo({ top: 0, behavior: 'smooth' });
      },

      startRitual() {
        this.ritualStarted = true;
        localStorage.setItem('tulayraa_ritual_started', 'true');
        setTimeout(() => {
          const revealSection = document.querySelector('.ritual-addon-reveal');
          if (revealSection) {
            window.scrollTo({ top: revealSection.offsetTop - 100, behavior: 'smooth' });
          }
        }, 100);
      },

      toggleAddOn(addon) {
        const idStr = addon.id.toString();
        const index = this.selectedAddOns.findIndex(a => a.id.toString() === idStr);
        if (index > -1) {
          this.selectedAddOns.splice(index, 1);
        } else {
          this.selectedAddOns.push(addon);
        }
        // Force reactivity for Alpine
        this.selectedAddOns = [...this.selectedAddOns];
        localStorage.setItem('tulayraa_selected_addons', JSON.stringify(this.selectedAddOns));
      },

      isSelected(id) { 
        if (!id) return false;
        const idStr = id.toString();
        return this.selectedAddOns.some(a => a.id.toString() === idStr); 
      },

      get totalPrice() { return this.basePrice + this.selectedAddOns.reduce((sum, a) => sum + a.price, 0); },

      get totalPriceFormatted() {
        return (this.totalPrice / 100).toLocaleString('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 });
      },

      openModal() { this.modalOpen = true; document.body.style.overflow = 'hidden'; },
      closeModal() { this.modalOpen = false; document.body.style.overflow = ''; },

      async completeRitual() {
        this.loading = true;
        
        try {
          // 1. Clear cart to prevent duplicate rituals
          await fetch(window.Shopify.routes.root + 'cart/clear.js', { method: 'POST' });

          const items = [{
            id: this.variantId,
            quantity: 1,
            properties: {
              'Ritual Date': this.bookingDate,
              'Ritual Time': this.bookingTime,
              'Guest Notes': this.notes
            }
          }];

          this.selectedAddOns.forEach(addon => {
            if (addon.id && !addon.id.toString().includes('mock')) {
              items.push({
                id: addon.id,
                quantity: 1,
                properties: {
                   'Main Ritual': this.productTitle,
                   'Ritual Date': this.bookingDate
                }
              });
            }
          });

          // 2. Add new ritual items
          const response = await fetch(window.Shopify.routes.root + 'cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ items })
          });

          if (response.ok) {
            // Success: Clear local storage and redirect
            localStorage.removeItem('tulayraa_ritual_started');
            localStorage.removeItem('tulayraa_selected_addons');
            window.location.href = '/cart';
          } else {
            const err = await response.json();
            alert('Booking Error: ' + (err.description || err.message));
            this.loading = false;
          }
        } catch (e) {
          console.error('Ritual addition failed:', e);
          alert('Something went wrong. Please try again.');
          this.loading = false;
        }
      }
    }
  }
</script>

