{% if product.metafields.custom.add_on_services.value != blank %}
<div 
  class="tulayraa-ritual-experience" 
  x-data="tulayraaRitual()" 
  x-init="init()"
>
  <div class="page-width">
    <div class="ritual-pdp-grid">
      
      <!-- LEFT SIDE (45%): Editorial Gallery -->
      <div class="ritual-gallery-side">
        <div class="editorial-gallery">
          <div class="gallery-main-wrapper">
             {% if product.featured_image %}
               <img 
                 src="{{ product.featured_image | image_url: width: 1400 }}" 
                 class="gallery-main-img" 
                 alt="{{ product.title }}"
                 loading="eager"
                 x-ref="mainImg"
               >
             {% endif %}
              {% if product.images.size > 1 %}
                <!-- Navigation Arrows -->
                <button class="gallery-nav prev" @click="prevImage()">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
                </button>
                <button class="gallery-nav next" @click="nextImage()">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
                </button>

                <!-- Image Counter -->
                <div class="gallery-counter">
                  <span x-text="currentImageIndex + 1"></span> / {{ product.images.size }}
                </div>
              {% endif %}
           </div>
           
           {% if product.images.size > 1 %}
             <!-- Horizontal Thumbnails -->
             <div class="gallery-thumbs-horizontal">
               {% for image in product.images %}
                 <div 
                   class="gallery-thumb-item" 
                   :class="{ 'active': currentImageIndex === {{ forloop.index0 }} }"
                   @click="updateMainImage('{{ image | image_url: width: 1400 }}', {{ forloop.index0 }})"
                 >
                   <img src="{{ image | image_url: width: 200 }}" alt="Thumbnail">
                 </div>
               {% endfor %}
             </div>
           {% endif %}
          </div>
        </div>

      <!-- RIGHT SIDE (55%): Content Area -->
      <div class="ritual-content-side">
        <div class="ritual-sticky-wrapper">
          <h1 class="ritual-main-title-v2">{{ product.title }}</h1>
          
          <div class="ritual-short-desc">
             {{ product.description }}
          </div>

          <div class="ritual-meta-grid">
             <div class="meta-card">
                <div class="meta-card__icon">
                   <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                </div>
                <div class="meta-card__text">
                   <span class="meta-label">Duration</span>
                   <span class="meta-value">{{ product.metafields.custom.duration | default: '90' }} mins</span>
                </div>
             </div>
             <div class="meta-card">
                <div class="meta-card__icon">
                   <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path><line x1="7" y1="7" x2="7.01" y2="7"></line></svg>
                </div>
                <div class="meta-card__text">
                   <span class="meta-label">Starting Price</span>
                   <span class="meta-value">{{ product.price | money }}</span>
                </div>
             </div>
          </div>

          <div class="ritual-inclusions-v2">
             <div class="inclusion-title">RITUAL INCLUSIONS</div>
             <div class="inclusions-grid-2x2">
                <div class="inclusion-item">
                   <div class="inclusion-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg></div>
                   <span>Professional Consultation</span>
                </div>
                <div class="inclusion-item">
                   <div class="inclusion-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 3h12l1 9H5l1-9z"></path><path d="M9 12v8a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2v-8"></path></svg></div>
                   <span>Signature Gel Application</span>
                </div>
                <div class="inclusion-item">
                   <div class="inclusion-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg></div>
                   <span>Premium Aftercare Oil</span>
                </div>
                <div class="inclusion-item">
                   <div class="inclusion-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg></div>
                   <span>Home Service Excellence</span>
                </div>
             </div>
          </div>

          <!-- CTA BUTTON -->
          {% if product.metafields.custom.add_on_services.value != blank %}
            <div class="ritual-primary-action" x-show="!ritualStarted">
              <button class="tulayraa-ritual-btn book-now-style" @click="startRitual()">
                Start Ritual <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </button>
            </div>
          {% endif %}

          <!-- REVEALED SECTION: COMPLETE YOUR RITUAL (INLINE) -->
          {% if product.metafields.custom.add_on_services.value != blank %}
            <div 
              class="ritual-addon-reveal" 
              x-show="ritualStarted" 
              x-transition:enter="ritual-expand-enter"
              x-cloak
              style="margin-top: 3rem;"
            >
               <div class="addon-header">
                  <h2 class="addon-title">Complete Your Ritual</h2>
                  <p class="addon-subtitle" style="font-size: 0.9rem; opacity: 0.6; margin-top: 0.5rem;">Enhance your experience with thoughtful finishing touches.</p>
               </div>

               <div class="addon-list-v2" style="margin-top: 2rem; display: flex; flex-direction: column; gap: 1.5rem;">
                   {% for addon in product.metafields.custom.add_on_services.value %}
                      <div class="addon-group-v2">
                         <div class="luxury-addon-row" :class="{ 'is-selected': isSelected({{ addon.variants.first.id | json }}) }" @click='toggleAddOn({
                                    id: {{ addon.variants.first.id | json }},
                                    title: {{ addon.title | json }},
                                    price: {{ addon.variants.first.price | json }},
                                    priceFormatted: {{ addon.variants.first.price | money | json }},
                                    image: {% if addon.featured_image %}{{ addon.featured_image | image_url: width: 100 | json }}{% else %}null{% endif %}
                                  })'>
                            <div class="addon-row__img">
                               {% if addon.featured_image %}
                                  <img src="{{ addon.featured_image | image_url: width: 120 }}" loading="lazy">
                               {% endif %}
                            </div>
                            <div class="addon-row__info">
                               <h3 class="addon-name">{{ addon.title }}</h3>
                               <span class="addon-price">{{ addon.price | money }}</span>
                            </div>
                            <button class="addon-add-btn" :class="{ 'added': isSelected({{ addon.variants.first.id | json }}) }">
                               <span x-text="isSelected({{ addon.variants.first.id | json }}) ? 'Added' : 'Add'"></span>
                            </button>
                         </div>

                         <!-- NESTED SUB-ADDONS (Level 2) -->
                         {% if addon.metafields.custom.adonproduct.value != blank %}
                            <div class="sub-addons-tray" 
                                 x-show="isSelected({{ addon.variants.first.id | json }})"
                                 x-transition:enter="sub-reveal-up"
                                 x-cloak>
                               <div class="sub-addons-header">
                                  <div class="sub-header-line"></div>
                                  <span>ENHANCEMENTS FOR {{ addon.title | upcase }}</span>
                               </div>
                               <div class="sub-addons-list">
                                  {% for sub_addon in addon.metafields.custom.adonproduct.value %}
                                     <div class="sub-addon-row" 
                                          :class="{ 'sub-selected': isSelected({{ sub_addon.variants.first.id | json }}) }"
                                          @click.stop='toggleAddOn({
                                             id: {{ sub_addon.variants.first.id | json }},
                                             title: {{ sub_addon.title | json }},
                                             price: {{ sub_addon.variants.first.price | json }},
                                             priceFormatted: {{ sub_addon.variants.first.price | money | json }},
                                             image: {% if sub_addon.featured_image %}{{ sub_addon.featured_image | image_url: width: 100 | json }}{% else %}null{% endif %}
                                          })'>
                                        <div class="sub-addon-visual">
                                           {% if sub_addon.featured_image %}
                                              <div class="sub-addon-img">
                                                 <img src="{{ sub_addon.featured_image | image_url: width: 80 }}" loading="lazy">
                                              </div>
                                           {% endif %}
                                           <div class="sub-addon-info">
                                              <span class="sub-addon-name">{{ sub_addon.title }}</span>
                                              <span class="sub-addon-price">+ {{ sub_addon.price | money }}</span>
                                           </div>
                                        </div>
                                        <button class="sub-addon-plus" :class="{ 'added': isSelected({{ sub_addon.variants.first.id | json }}) }">
                                           <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" x-show="!isSelected({{ sub_addon.variants.first.id | json }})"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                                           <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" x-show="isSelected({{ sub_addon.variants.first.id | json }})"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                        </button>
                                     </div>
                                  {% endfor %}
                               </div>
                            </div>
                         {% endif %}
                      </div>
                   {% endfor %}
               </div>
            </div>
          {% endif %}

          <!-- Bottom Perks -->
          <div class="ritual-perks-row-v2">
             <div class="perk-card-v2">
                <div class="perk-icon-bg"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg></div>
                <span>Premium Products</span>
             </div>
             <div class="perk-card-v2">
                <div class="perk-icon-bg"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg></div>
                <span>Trained Experts</span>
             </div>
             <div class="perk-card-v2">
                <div class="perk-icon-bg"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"></circle><path d="M12 8v4l3 3"></path></svg></div>
                <span>Hygienic Tools</span>
             </div>
             <div class="perk-card-v2">
                <div class="perk-icon-bg"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path></svg></div>
                <span>At-Home Comfort</span>
             </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- STICKY LUXURY BOOKING BAR (only for products with add-ons) -->
  <div 
    class="ritual-sticky-bar-wrapper" 
    x-show="ritualStarted" 
    x-transition:enter="bar-slide-up"
    x-cloak
  >
     <!-- SELECTION SUMMARY TRAY (Accordion) -->
     <div 
       class="ritual-pill-summary" 
       x-show="summaryOpen" 
       x-transition:enter="summary-slide-up"
       x-transition:leave="summary-slide-down"
     >
        <div class="summary-header">
           <span>SELECTED SERVICES</span>
           <button @click="summaryOpen = false" class="summary-close">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
           </button>
        </div>
        <div class="summary-items-list">
           <!-- MAIN SERVICE -->
           <div class="summary-item main-service">
              <div class="item-visual-group">
                 <div class="summary-item-img">
                    <img src="{{ product.featured_image | image_url: width: 100 }}" alt="{{ product.title }}">
                 </div>
                 <span class="item-name">{{ product.title }}</span>
              </div>
              <button class="remove-item-btn" @click="resetRitual()">
                 <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
              </button>
           </div>
           
           <!-- ADDONS -->
           <template x-for="addon in selectedAddOns" :key="addon.id">
              <div class="summary-item addon-service">
                 <div class="item-visual-group">
                    <div class="summary-item-img">
                       <img :src="addon.image" :alt="addon.title">
                    </div>
                    <span class="item-name" x-text="addon.title"></span>
                 </div>
                 <button class="remove-item-btn" @click="toggleAddOn(addon)">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                 </button>
              </div>
           </template>
        </div>
     </div>

     <div class="ritual-pill-bar">
        <div class="pill-bar__left">
           <div class="selection-count" @click="summaryOpen = !summaryOpen" style="cursor: pointer;">
              <span x-text="selectedAddOns.length + 1"></span>
           </div>
           <div class="price-stack">
              <div class="pill-price" x-text="totalPriceFormatted"></div>
              <div class="pill-label">TOTAL RITUAL VALUE</div>
           </div>
        </div>
        <div class="pill-bar__right">
           <button class="book-now-btn" @click="openModal()">
              BOOK NOW <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
           </button>
        </div>
     </div>
  </div>

  <!-- LUXURY BOOKING MODAL (FULLSCREEN) -->
  <div class="ritual-booking-modal" x-show="modalOpen" x-transition x-cloak>
    <div class="modal-overlay" @click="closeModal()" style="background-image: url('https://cdn.shopify.com/s/files/1/0664/0658/0287/files/ChatGPT_Image_May_13_2026_04_50_36_PM.png?v=1778671273'); background-size: cover; background-position: center;"></div>
    <div class="booking-modal__content" style="max-width: 900px; z-index: 2001;">
      <!-- Sidebar -->
      <aside class="booking-sidebar" style="width: 35%;">
        <div class="booking-brand">
          <h2 class="booking-brand__name">Tulayraa</h2>
          <p class="booking-brand__tagline">The Art of Intentional Beauty</p>
        </div>

        <nav class="booking-steps">
          <div class="booking-step" :class="{ 'active': currentStep === 1 }">
            <div class="step-number">1</div>
            <div class="step-info">
              <span class="step-title">Date & Time</span>
              <span class="step-desc">Select your ritual moment</span>
            </div>
          </div>
          <div class="booking-step" :class="{ 'active': currentStep === 2 }">
            <div class="step-number">2</div>
            <div class="step-info">
              <span class="step-title">Confirmation</span>
              <span class="step-desc">Personalize your experience</span>
            </div>
          </div>
        </nav>

        <div class="booking-sidebar__footer">
          <div class="ritual-preview">
            <span class="ritual-preview__name">{{ product.title }}</span>
            <h3 class="ritual-preview__price" x-text="totalPriceFormatted"></h3>
          </div>
        </div>
      </aside>

      <!-- Main Content -->
      <main class="booking-main" style="width: 65%;">
        <!-- Step 1: Date & Time -->
        <div x-show="currentStep === 1" x-transition>
          <h2 class="booking-main__title">Select a Date</h2>
          
          <div class="calendar-nav">
            <button @click="prevMonth()" class="calendar-arrow" style="background:none; border:none; cursor:pointer;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
            </button>
            <span class="calendar-month" x-text="monthNames[currentMonth] + ' ' + currentYear"></span>
            <button @click="nextMonth()" class="calendar-arrow" style="background:none; border:none; cursor:pointer;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </button>
          </div>

          <div class="calendar-grid">
            <div class="calendar-weekday">Su</div>
            <div class="calendar-weekday">Mo</div>
            <div class="calendar-weekday">Tu</div>
            <div class="calendar-weekday">We</div>
            <div class="calendar-weekday">Th</div>
            <div class="calendar-weekday">Fr</div>
            <div class="calendar-weekday">Sa</div>
            
            <template x-for="day in days">
              <div 
                class="calendar-day" 
                :class="{ 'selected': bookingDate === day.full, 'disabled': !day.num || !day.available }" 
                x-text="day.num"
                @click="if(day.available) bookingDate = day.full"
              ></div>
            </template>
          </div>

          <div class="times-section">
            <h4 class="times-title">Available Times</h4>
            <div class="time-slots">
              <template x-for="slot in timeSlots">
                <div 
                  class="time-slot" 
                  :class="{ 'selected': bookingTime === slot }" 
                  x-text="slot"
                  @click="bookingTime = slot"
                ></div>
              </template>
            </div>
          </div>
        </div>

        <!-- Step 2: Confirmation -->
        <div x-show="currentStep === 2" x-transition>
           <h2 class="booking-main__title">Confirm Your Ritual</h2>
           <div class="glass-effect" style="padding: 2.5rem; margin-top: 1rem; border-radius: 30px; background: #F8F8F6;">
             <p style="font-size: 1.1rem; margin-bottom: 1.5rem; color: #666;">You are booking your ritual for:</p>
             <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-bottom: 2rem;">
               <div>
                 <label style="font-size: 0.8rem; text-transform: uppercase; opacity: 0.5; font-weight: 700;">Date</label>
                 <p style="font-size: 1.3rem; font-weight: 600;" x-text="bookingDate"></p>
               </div>
               <div>
                 <label style="font-size: 0.8rem; text-transform: uppercase; opacity: 0.5; font-weight: 700;">Time</label>
                 <p style="font-size: 1.3rem; font-weight: 600;" x-text="bookingTime"></p>
               </div>
             </div>
             <label style="font-size: 0.8rem; text-transform: uppercase; opacity: 0.5; font-weight: 700; display: block; margin-bottom: 0.5rem;">Special Notes</label>
             <textarea x-model="notes" class="luxury-textarea" style="background: white; min-height: 120px;" placeholder="Any special requests or preferences?"></textarea>
           </div>
        </div>

        <!-- Footer -->
        <footer class="booking-footer" style="display: flex; flex-direction: column; gap: 1.5rem; margin-top: auto; padding-top: 2rem;">
          <div x-show="showError" x-transition class="error-msg" style="background: #FFF5F5; color: #E63946; padding: 1rem 1.5rem; border-radius: 12px; font-size: 0.9rem; font-weight: 600; text-align: center; border: 1px solid #FFEBEB;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="display: inline; margin-right: 8px; vertical-align: middle;"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
            Please select both date and time to continue.
          </div>

          <div style="display: flex; justify-content: flex-end; gap: 1rem; width: 100%;">
            <button class="btn-cancel" @click="currentStep > 1 ? currentStep = 1 : closeModal()" style="height: 54px; min-width: 120px; border: 1.5px dashed #D0D0D0; background: none; border-radius: 100px; display: flex; align-items: center; justify-content: center; gap: 0.8rem; font-weight: 600; cursor: pointer; color: #777;">
              <span x-text="currentStep === 1 ? 'Cancel' : 'Back'"></span>
            </button>
            
            <button 
              class="btn-continue" 
              :class="{ 'shake-anim': showError }"
              @click="handleContinue()" 
              style="height: 54px; flex: 1; max-width: 240px; background: var(--ritual-charcoal); color: white; border: none; border-radius: 100px; display: flex; align-items: center; justify-content: center; gap: 1.2rem; font-weight: 600; cursor: pointer; transition: all 0.3s ease;"
            >
              <span x-show="!loading" x-text="currentStep === 1 ? 'Continue' : 'Add to Cart'"></span>
              <span x-show="loading">Adding...</span>
              <svg x-show="!loading" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </button>
          </div>
        </footer>
      </main>
    </div>
  </div>
</div> <!-- End of tulayraa-ritual-experience -->

{% else %}
  <!-- PREMIUM STANDARD PRODUCT LAYOUT (Refined to match high-fidelity screenshot) -->
  <div class="tulayraa-ritual-experience tulayraa-standard-pdp-v2">
    <div class="page-width">
      <div class="ritual-pdp-grid">
        
        <!-- LEFT SIDE (45%): Editorial Gallery -->
        <div class="ritual-gallery-side">
          <div class="editorial-gallery">
            <div class="gallery-main-wrapper">
               {% if product.featured_image %}
                 <img 
                   src="{{ product.featured_image | image_url: width: 1400 }}" 
                   class="gallery-main-img" 
                   alt="{{ product.title }}"
                   loading="eager"
                   x-ref="mainImg"
                 >
               {% endif %}
            </div>

            {% if product.images.size > 1 %}
              <div class="gallery-thumbs-horizontal" style="margin-top: 2rem;">
                {% for image in product.images %}
                  <div class="gallery-thumb-item" onclick="document.querySelector('.gallery-main-img').src='{{ image | image_url: width: 1400 }}'">
                    <img src="{{ image | image_url: width: 200 }}" alt="Thumbnail">
                  </div>
                {% endfor %}
              </div>
            {% endif %}
          </div>
        </div>

        <!-- RIGHT SIDE: Content Area -->
        <div class="ritual-content-side">
          <div class="ritual-sticky-wrapper">
            <div class="ritual-vendor-label">{{ product.vendor }}</div>
            <h1 class="ritual-main-title-v2">{{ product.title }}</h1>
            
            <div class="ritual-short-desc">
              {{ product.description }}
            </div>

            <div class="ritual-meta-grid">
               <div class="meta-card">
                  <div class="meta-card__icon">
