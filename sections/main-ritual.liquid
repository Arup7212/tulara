  .ritual-preview__price { font-family: var(--font-heading-family); font-size: 2rem; margin-top: 0.5rem; color: var(--ritual-charcoal); }

  .booking-main { width: 65%; padding: 4rem 5rem; display: flex; flex-direction: column; overflow-y: auto; background: white; }
  .booking-main__title { font-family: var(--font-heading-family); font-size: 2.4rem; margin-bottom: 2.5rem; color: var(--ritual-charcoal); }

  .calendar-nav { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
  .calendar-month { font-size: 1.1rem; font-weight: 600; }
  .calendar-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 0.5rem; text-align: center; }
  .calendar-weekday { font-size: 0.75rem; opacity: 0.4; text-transform: uppercase; font-weight: 700; padding-bottom: 1.5rem; }
  .calendar-day { aspect-ratio: 1; display: flex; align-items: center; justify-content: center; cursor: pointer; border-radius: 50%; font-size: 1rem; transition: 0.3s; }
  .calendar-day:hover:not(.disabled) { background: #F5F5F0; }
  .calendar-day.selected { background: var(--ritual-charcoal); color: white; transform: scale(1.1); }
  .calendar-day.disabled { opacity: 0.15; cursor: not-allowed; }

  .times-section { margin-top: 3.5rem; }
