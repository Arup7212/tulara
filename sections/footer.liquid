

<div
  class="footer-section-outer color-{{ section.settings.color_scheme }}"
  style="background-color: var(--color-background); width: 100%;"
>
  {% liquid
    assign total_blocks = section.blocks.size
    assign grid_columns = total_blocks | at_most: 5
  %}
  <div
    class="footer-content"
    style="--grid-columns: {{ grid_columns }};"
  >
    {% content_for 'blocks' %}
  </div>
</div>

{% stylesheet %}
  .section-wrapper:has(.footer-content) {
    border: none !important;
  }

  .footer-content {
    display: flex;
    flex-direction: column;
    gap: 40px;
    padding: 40px 20px;
    width: 100%;
    margin: 0 auto;
    max-width: var(--page-width, 1440px);
  }

  @media screen and (min-width: 990px) {
    .footer-content {
      display: grid;
      gap: 0;
      align-items: start;
    }

    /* 5-column layout for the target design */
    .footer-content[style*="--grid-columns: 5"] {
      grid-template-columns: 1.5fr 1fr 1fr 1fr 1.5fr;
    }

    /* Dynamic layouts for fewer blocks */
    .footer-content[style*="--grid-columns: 4"] {
      grid-template-columns: 1.5fr 1fr 1fr 1.5fr;
    }

    .footer-content[style*="--grid-columns: 3"] {
      grid-template-columns: 1.5fr 1fr 1.5fr;
    }

    .footer-content[style*="--grid-columns: 2"] {
      grid-template-columns: 1.5fr 1.5fr;
      justify-content: space-between;
    }

    /* Vertical dividers for middle columns - only if there are enough blocks */
    .footer-content[style*="--grid-columns: 5"] > *:not(:first-child):not(:last-child),
    .footer-content[style*="--grid-columns: 4"] > *:not(:first-child):not(:last-child),
    .footer-content[style*="--grid-columns: 3"] > *:nth-child(2) {
      border-left: 1px solid var(--color-border, rgba(139, 94, 60, 0.1));
      padding-left: 25px;
      padding-right: 15px;
    }

    .footer-content > *:first-child {
      padding-right: 25px;
    }

    .footer-content > *:last-child {
      padding-left: 25px;
    }
  }

  .footer-content .menu__heading__default,
  .footer-content .email-signup__heading {
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 13px;
    margin-bottom: 5px;
    color: var(--color-foreground, #8B5E3C);
    display: block;
    line-height: 1.2;
  }

  @media screen and (max-width: 989px) {
    .footer-content {
      display: grid !important;
      grid-template-columns: 1fr 1fr !important;
      gap: 30px 20px !important;
      text-align: left;
      padding: 30px 20px !important;
    }
    
    .footer-content > * {
      border-left: none !important;
      padding-left: 0 !important;
      padding-right: 0 !important;
    }

    /* Left-align footer menu and title on mobile, making them grid columns */
    .footer-content .menu {
      grid-column: span 1 !important;
      text-align: left !important;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      width: 100%;
    }

    .footer-content .menu__details {
      width: 100%;
      text-align: left !important;
    }

    .footer-content .menu__heading {
      text-align: left !important;
      justify-content: flex-start !important;
      width: 100%;
    }

    .footer-content .menu__heading__default {
      text-align: left !important;
      width: 100%;
      display: block;
    }

    .footer-content .menu__heading__accordion {
      justify-content: flex-start !important;
      text-align: left !important;
    }

    .footer-content .menu__item {
      text-align: left !important;
    }



    /* Center-align logo and social icons block on mobile, spanning full width */
    .footer-content .logo-block {
      grid-column: 1 / -1 !important;
      margin: 0 auto !important;
      justify-content: center !important;
      text-align: center !important;
    }

    .footer-content .logo-block__content {
      align-items: center !important;
      text-align: center !important;
      margin: 0 auto !important;
    }

    .footer-content .logo-block__image-wrapper {
      justify-content: center !important;
    }

    .footer-content .logo-block__social {
      justify-content: center !important;
    }

    /* Center-align standalone social icons wrapper on mobile */
    .footer-content .social-icons__wrapper {
      justify-content: center !important;
      margin-left: auto !important;
      margin-right: auto !important;
    }

    /* Center-align newsletter/email signup block on mobile, spanning full width */
    .footer-content .email-signup-block {
      grid-column: 1 / -1 !important;
      margin: 0 auto !important;
      text-align: center !important;
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
    }

    .footer-content .email-signup__heading {
      text-align: center !important;
      width: 100% !important;
    }

    .footer-content .email-signup__description {
      text-align: center !important;
      width: 100% !important;
    }

    .footer-content .email-signup__form {
      align-items: center !important;
      width: 100% !important;
    }

    .footer-content .email-signup__input-group {
      margin: 0 auto !important;
      width: 100% !important;
      max-width: 400px !important;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.footer",
  "class": "section-wrapper",
  "blocks": [
    {
      "type": "_divider"
    },
    {
      "type": "@app"
    },
    {
      "type": "button"
    },
    {
      "type": "follow-on-shop"
    },
    {
      "type": "group"
    },
    {
      "type": "icon"
    },
    {
      "type": "image"
    },
    {
      "type": "menu"
    },
    {
      "type": "payment-icons"
    },
    {
      "type": "text"
    },
    {
      "type": "logo"
    },
    {
      "type": "jumbo-text"
    },
    {
      "type": "social-links"
    },
    {
      "type": "email-signup"
    }
  ],
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "t:names.footer",
      "category": "t:categories.footer",
      "settings": {
        "gap": 20,
        "color_scheme": "scheme-1",
        "padding-block-start": 36,
        "padding-block-end": 36
      },
      "blocks": {
        "newsletter-group": {
          "type": "group",
          "settings": {
            "content_direction": "column",
            "vertical_on_mobile": true,
            "horizontal_alignment": "flex-start",
            "vertical_alignment": "center",
            "gap": 6,
            "width": "fill",
            "inherit_color_scheme": true
          },
          "blocks": {
            "newsletter-heading": {
              "type": "text",
              "settings": {
                "text": "t:html_defaults.join_our_email_list",
                "width": "100%",
                "alignment": "left",
                "type_preset": "h3"
              }
            },
            "newsletter-text": {
              "type": "text",
              "settings": {
                "text": "t:html_defaults.get_exclusive_deals_and_early_access_to_new_products",
                "width": "100%",
                "alignment": "left",
                "type_preset": "rte"
              }
            }
          },
          "block_order": ["newsletter-heading", "newsletter-text"]
        },
        "newsletter-form": {
          "type": "email-signup",
          "settings": {
            "width": "fill"
          }
        }
      },
      "block_order": ["newsletter-group", "newsletter-form"]
    }
  ]
}
{% endschema %}
