{%- style -%}
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap');

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .philosophy-{{ section.id }} .tulayraa-philosophy__title {
    color: var(--color-foreground);
  }

  {% if section.settings.shadow_image != blank %}
    .philosophy-{{ section.id }} .shadow-play-overlay {
      background-image: url('{{ section.settings.shadow_image | image_url: width: 2000 }}') !important;
      opacity: 0.1;
    }
  {% endif %}
{%- endstyle -%}

<div class="tulayraa-philosophy philosophy-{{ section.id }} section-{{ section.id }}-padding">
  <!-- Shadow Play Overlay -->
  <div class="shadow-play-overlay"></div>

  <div class="page-width">
    <div class="tulayraa-philosophy__grid {% if section.settings.image_position == 'right' %}grid-reverse{% endif %}">
      
      <!-- Text Content -->
      <div class="tulayraa-philosophy__content" data-aos="fade-right">
        {% if section.settings.tagline != blank %}
          <div class="tulayraa-philosophy__tagline-wrapper">
            <span class="tulayraa-hero__tagline">{{ section.settings.tagline }}</span>
            <span class="tagline-line"></span>
          </div>
        {% endif %}
        
        {% if section.settings.title != blank %}
          <h2 class="tulayraa-philosophy__title">{{ section.settings.title }}</h2>
        {% endif %}

        <div class="tulayraa-philosophy__text-box">
          <div class="tulayraa-philosophy__description">
            {{ section.settings.description }}
          </div>
          {% if section.settings.quote != blank %}
            <div class="tulayraa-philosophy__accent-quote">
              “{{ section.settings.quote }}”
            </div>
          {% endif %}

          {% if section.settings.button_label != blank %}
            <div class="tulayraa-philosophy__actions">
              <a href="{{ section.settings.button_link }}" class="tulayraa-btn tulayraa-btn--primary">
                {{ section.settings.button_label }}
              </a>
            </div>
          {% endif %}
        </div>
      </div>

      <!-- Image Content -->
      <div class="tulayraa-philosophy__visual" data-aos="fade-left">
        <div class="image-container" style="width: {{ section.settings.image_width }}%;">
          {% if section.settings.image != blank %}
            {{ section.settings.image | image_url: width: 1000 | image_tag: class: 'philosophy-img', loading: 'lazy' }}
          {% else %}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg philosophy-img' }}
          {% endif %}
        </div>
      </div>

    </div>
  </div>
</div>

<style>
  .tulayraa-philosophy {
    position: relative;
    overflow: hidden;
    background: transparent;
  }

  .shadow-play-overlay {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0.08;
    pointer-events: none;
    z-index: 1;
  }

  .tulayraa-philosophy__grid {
    display: flex;
    align-items: center;
    gap: 8rem;
    position: relative;
    z-index: 2;
  }

  .tulayraa-philosophy__grid.grid-reverse {
    flex-direction: row-reverse;
  }

  .tulayraa-philosophy__content {
    flex: 1;
  }

  .tulayraa-philosophy__visual {
    flex: 1;
    display: flex;
    justify-content: center;
  }

  .tulayraa-philosophy__tagline-wrapper {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .tagline-line {
    width: 40px;
    height: 1px;
    background: #E2E8F0;
    display: inline-block;
  }

  .tulayraa-hero__tagline {
    text-transform: capitalize;
    color: var(--color-foreground);
    font-weight: 500;
  }

  .tulayraa-philosophy__title {
    color: var(--color-foreground);
    margin-bottom: 2rem;
  }

  .tulayraa-philosophy__description {
    color: var(--color-foreground);
    margin-bottom: 2.5rem;
    max-width: 450px;
    opacity: 0.8;
  }

  .tulayraa-philosophy__accent-quote {
    color: var(--color-foreground);
    margin-bottom: 3rem;
    opacity: 0.8;
    font-style: italic;
  }

  .image-container {
    position: relative;
    aspect-ratio: 1/1.15;
    margin: 0 auto;
  }

  .philosophy-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 120px 10px 120px 10px; /* Refined arch matching reference */
    box-shadow: 0 40px 80px rgba(0,0,0,0.04);
  }

  .tulayraa-btn--primary {
    background: #5D5E4A;
    color: white;
    padding: 1.2rem 3rem;
    font-size: 0.75rem;
    border-radius: 2px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 600;
    text-decoration: none;
    display: inline-block;
    transition: 0.3s ease;
  }

  @media screen and (max-width: 749px) {
    .tulayraa-philosophy__grid {
      flex-direction: column !important;
      text-align: center;
      gap: 2.5rem;
    }
    .tulayraa-philosophy {
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }
    .tulayraa-philosophy__title {
      font-size: clamp(2rem, 10vw, 2.5rem) !important;
      margin-bottom: 1.5rem;
    }
    .tulayraa-philosophy__description {
      margin: 0 auto 1.5rem;
    }
    .tulayraa-philosophy__visual .image-container {
      width: 100% !important;
    }
  }
</style>

{% schema %}
{
  "name": "Tulayraa Philosophy",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "shadow_image",
      "label": "Shadow Play Image (Tree branches)"
    },
    {
      "type": "header",
      "content": "Content Layout"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Philosophy Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image Position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "right"
    },
    {
      "type": "range",
      "id": "image_width",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Image Width (Desktop)",
      "default": 75
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "inline_richtext",
      "id": "tagline",
      "label": "Tagline",
      "default": "Time to Prioritize You"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Heading",
      "default": "Balance is the New Beauty."
    },

    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>We believe that beauty is not just about the final result, but the journey of returning to yourself. Our salon brings the sanctuary to you.</p>"
    },
    {
      "type": "inline_richtext",
      "id": "quote",
      "label": "Accent Quote",
      "default": "A Sanctuary Brought to Life."
    },
    {
      "type": "header",
      "content": "Call to Action"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Explore Rituals"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Tulayraa Philosophy"
    }
  ]
}
{% endschema %}
