<div 
  class="tulayraa-ritual-builder" 
  x-data="ritualBuilder()" 
  x-init="init()"
  {{ block.shopify_attributes }}
>
  <!-- Main Ritual Information (Editorial Style) -->
  <div class="ritual-pdp-main">
    <div class="ritual-pdp-header">
      <div class="ritual-vendor">{{ product.vendor }}</div>
      <h1 class="ritual-pdp-title">{{ product.title }}</h1>
      <div class="ritual-pdp-meta">
        <div class="pdp-meta-item">
          <span class="pdp-meta-label">Treatment Price</span>
          <span class="pdp-meta-value">{{ product.price | money }}</span>
        </div>
        <div class="pdp-meta-item">
          <span class="pdp-meta-label">Duration</span>
          <span class="pdp-meta-value">{{ product.metafields.custom.duration | default: '90' }} mins</span>
        </div>
      </div>
    </div>

    <div class="ritual-pdp-description">
      {{ product.description }}
    </div>

    <div class="ritual-benefits-grid">
       <div class="benefit-tag">Luxury Atmosphere</div>
       <div class="benefit-tag">Expert Ritualists</div>
       <div class="benefit-tag">Premium Products</div>
    </div>
  </div>

  <!-- Add-ons Section (The "Build" Step) -->
  <div class="ritual-addons-section">
     <div class="ritual-divider-line"></div>
     <h2 class="ritual-addons-title">Complete Your Ritual</h2>
     <p class="ritual-addons-subtitle">Enhance your experience with curated additions.</p>

     <div class="addons-list-container">
        {% if product.metafields.custom.add_on_services.value != blank %}
          {% for addon in product.metafields.custom.add_on_services.value %}
            <div 
              class="addon-card-luxury" 
              :class="{ 'selected': isSelected('{{ addon.variants.first.id }}') }"
            >
              <div class="addon-card__left">
                 {% if addon.featured_image %}
                   <img src="{{ addon.featured_image | image_url: width: 150 }}" class="addon-card__img" loading="lazy">
                 {% endif %}
                 <div class="addon-card__details">
                    <h4 class="addon-card__name">{{ addon.title }}</h4>
                    <div class="addon-card__meta">
                       <span>{{ addon.price | money }}</span>
                       <span class="dot-sep">•</span>
                       <span>{{ addon.metafields.custom.duration | default: '20' }} mins</span>
                    </div>
                 </div>
              </div>
              <div class="addon-card__right">
                 <button 
                   class="addon-add-btn" 
                   @click="toggleAddOn({
                     id: '{{ addon.variants.first.id }}',
                     title: '{{ addon.title }}',
                     price: {{ addon.price }},
                     priceFormatted: '{{ addon.price | money }}'
                   })"
                   :class="{ 'active': isSelected('{{ addon.variants.first.id }}') }"
                 >
                   <span x-text="isSelected('{{ addon.variants.first.id }}') ? 'Added' : 'Add +'"></span>
                 </button>
              </div>
            </div>
          {% endfor %}
        {% else %}
           <!-- MOCKED FOR PREVIEW TO MATCH SCREENSHOT -->
           <template x-for="item in mockAddOns">
              <div class="addon-card-luxury" :class="{ 'selected': isSelected(item.id) }">
                 <div class="addon-card__left">
                    <img :src="item.image" class="addon-card__img">
                    <div class="addon-card__details">
                       <h4 class="addon-card__name" x-text="item.title"></h4>
                       <div class="addon-card__meta">
                          <span x-text="item.priceFormatted"></span>
                          <span class="dot-sep">•</span>
                          <span x-text="item.duration + ' mins'"></span>
                       </div>
                    </div>
                 </div>
                 <div class="addon-card__right">
                    <button 
                      class="addon-add-btn" 
                      @click="toggleAddOn(item)"
                      :class="{ 'active': isSelected(item.id) }"
                    >
                      <span x-text="isSelected(item.id) ? 'Added' : 'Add +'"></span>
                    </button>
                 </div>
              </div>
           </template>
        {% endif %}
     </div>
  </div>

  <!-- Sticky Ritual Bar (Pill Design) -->
  <div class="ritual-sticky-pill" x-show="totalPrice > basePrice || true" x-transition>
     <div class="sticky-pill__content">
        <div class="sticky-pill__left">
           <div class="cart-icon-badge">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
              <span class="badge-count" x-text="selectedAddOns.length + 1"></span>
           </div>
           <div class="sticky-pill__price-info">
              <div class="sticky-pill__total" x-text="totalPriceFormatted"></div>
              <div class="sticky-pill__label">Plus taxes</div>
           </div>
        </div>
        <button class="sticky-pill__btn" @click="openBooking()">
           Book Now
        </button>
     </div>
  </div>

  <!-- Step 4: Booking Section (Calendar - Revealed on Book Now) -->
  <div class="ritual-booking-overlay" x-show="bookingOpen" x-transition x-cloak>
    <div class="booking-modal__content" style="max-width: 900px;">
      <!-- Sidebar -->
      <aside class="booking-sidebar" style="width: 35%;">
        <div class="booking-brand">
          <h2 class="booking-brand__name">Tulayraa</h2>
          <p class="booking-brand__tagline">The Art of Intentional Beauty</p>
        </div>

        <nav class="booking-steps">
          <div class="booking-step active">
            <div class="step-number">1</div>
            <div class="step-info">
              <span class="step-title">Date & Time</span>
              <span class="step-desc">Select your ritual moment</span>
            </div>
          </div>
          <div class="booking-step" style="opacity: 0.25;">
            <div class="step-number">2</div>
            <div class="step-info">
              <span class="step-title">Details</span>
              <span class="step-desc">Personalize your experience</span>
            </div>
          </div>
        </nav>

        <div class="booking-sidebar__footer">
          <div class="ritual-preview">
            <span class="ritual-preview__name">{{ product.title }}</span>
            <h3 class="ritual-preview__price" x-text="totalPriceFormatted"></h3>
          </div>
        </div>
      </aside>

      <!-- Main Content -->
      <main class="booking-main" style="width: 65%;">
        <div x-show="!loading">
          <h2 class="booking-main__title">Select a Date</h2>
          
          <div class="calendar-nav">
            <button @click="prevMonth()" class="calendar-arrow" style="background:none; border:none; cursor:pointer;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
            </button>
            <span class="calendar-month" x-text="monthNames[currentMonth] + ' ' + currentYear"></span>
            <button @click="nextMonth()" class="calendar-arrow" style="background:none; border:none; cursor:pointer;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </button>
          </div>

          <div class="calendar-grid">
            <div class="calendar-weekday">Su</div>
            <div class="calendar-weekday">Mo</div>
            <div class="calendar-weekday">Tu</div>
            <div class="calendar-weekday">We</div>
            <div class="calendar-weekday">Th</div>
            <div class="calendar-weekday">Fr</div>
            <div class="calendar-weekday">Sa</div>
            
            <template x-for="day in days">
              <div 
                class="calendar-day" 
                :class="{ 'selected': bookingDate === day.full, 'disabled': !day.num || !day.available }" 
                x-text="day.num"
                @click="if(day.available) bookingDate = day.full"
              ></div>
            </template>
          </div>

          <div class="times-section">
            <h4 class="times-title">Available Times</h4>
            <div class="time-slots">
              <template x-for="slot in timeSlots">
                <div 
                  class="time-slot" 
                  :class="{ 'selected': bookingTime === slot }" 
                  x-text="slot"
                  @click="bookingTime = slot"
                ></div>
              </template>
            </div>
          </div>
        </div>

        <!-- Footer -->
        <footer class="booking-footer">
          <button class="btn-cancel" @click="bookingOpen = false">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            <span>Cancel</span>
          </button>
          
          <button class="btn-continue" @click="reserveRitual()" :disabled="!isReadyToBook">
            <span x-show="!loading">Confirm Ritual</span>
            <span x-show="loading">Securing...</span>
            <svg x-show="!loading" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </button>
        </footer>
      </main>
    </div>
  </div>
</div>

<style>
