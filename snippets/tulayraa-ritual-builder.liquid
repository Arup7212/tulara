  @media screen and (max-width: 749px) {
    .ritual-pdp-title { font-size: 2.5rem; }
    .ritual-sticky-pill { width: calc(100% - 2rem); min-width: 0; }
    .sticky-pill__total { font-size: 1rem; }
    .sticky-pill__btn { padding: 0.75rem 1.5rem; }
  }
</style>

<script>
  function ritualBuilder() {
    return {
      selectedAddOns: [],
      bookingOpen: false,
      bookingDate: null,
      bookingTime: null,
      address: { full: '' },
      loading: false,
      currentMonth: new Date().getMonth(),
      currentYear: new Date().getFullYear(),
      monthNames: ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"],
      days: [],
      timeSlots: ['10:00 AM', '11:30 AM', '1:00 PM', '3:00 PM', '4:30 PM', '6:00 PM'],
      basePrice: {{ product.price }},

      mockAddOns: [
        { id: 'mock1', title: 'Chrome Finish', price: 39900, priceFormatted: '₹399', image: 'https://images.unsplash.com/photo-1604654894610-df490c8121bc?auto=format&fit=crop&q=80&w=200', duration: '20' },
        { id: 'mock2', title: 'French Tips', price: 29900, priceFormatted: '₹299', image: 'https://images.unsplash.com/photo-1519014816548-bf5fe059798b?auto=format&fit=crop&q=80&w=200', duration: '30' },
        { id: 'mock3', title: 'Cuticle Spa', price: 49900, priceFormatted: '₹499', image: 'https://images.unsplash.com/photo-1522337660859-02fbefca4702?auto=format&fit=crop&q=80&w=200', duration: '25' }
      ],

      init() {
        this.generateCalendar();
      },

      generateCalendar() {
        this.days = [];
        const firstDay = new Date(this.currentYear, this.currentMonth, 1).getDay();
        const daysInMonth = new Date(this.currentYear, this.currentMonth + 1, 0).getDate();
        
        for (let i = 0; i < firstDay; i++) {
          this.days.push({ num: '', full: '', available: false });
        }
        
        const now = new Date();
        now.setHours(0,0,0,0);

        for (let i = 1; i <= daysInMonth; i++) {
          const d = new Date(this.currentYear, this.currentMonth, i);
          this.days.push({
            num: i,
            full: d.toISOString().split('T')[0],
            available: d >= now
          });
        }
      },

      nextMonth() {
        if (this.currentMonth === 11) {
          this.currentMonth = 0;
          this.currentYear++;
        } else {
          this.currentMonth++;
        }
        this.generateCalendar();
      },

      prevMonth() {
        if (this.currentMonth === 0) {
          this.currentMonth = 11;
          this.currentYear--;
        } else {
          this.currentMonth--;
        }
        this.generateCalendar();
      },

      toggleAddOn(addon) {
        const index = this.selectedAddOns.findIndex(a => a.id === addon.id);
        if (index > -1) {
          this.selectedAddOns.splice(index, 1);
        } else {
          this.selectedAddOns.push(addon);
        }
      },

      isSelected(id) {
        return this.selectedAddOns.some(a => a.id === id);
      },

      get totalPrice() {
        return this.basePrice + this.selectedAddOns.reduce((sum, a) => sum + a.price, 0);
      },

      get totalPriceFormatted() {
        return (this.totalPrice / 100).toLocaleString('en-IN', {
          style: 'currency',
          currency: 'INR',
          maximumFractionDigits: 0
        });
      },

      get isReadyToBook() {
        return this.bookingDate && this.bookingTime;
      },

      openBooking() {
        this.bookingOpen = true;
      },

      async reserveRitual() {
        this.loading = true;
        const items = [{
          id: {{ product.selected_or_first_available_variant.id }},
          quantity: 1,
          properties: {
            'Date': this.bookingDate,
            'Time': this.bookingTime
          }
        }];

        this.selectedAddOns.forEach(addon => {
          items.push({ id: addon.id, quantity: 1 });
        });

        await fetch(window.Shopify.routes.root + 'cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items })
        });
        
        window.location.href = '/checkout';
      }
    }
  }
</script>
