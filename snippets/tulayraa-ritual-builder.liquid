  }

  .step-number {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #EAEAEA;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    font-weight: 700;
    flex-shrink: 0;
